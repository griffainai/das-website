# =============================================
# Driver Appreciation Solutions — Environment Variables
# Set these in Vercel: Project → Settings → Environment Variables
# For local dev: copy to .env.local (Vercel CLI reads this automatically)
# NEVER commit .env.local to git.
# =============================================

# Stripe — get from https://dashboard.stripe.com/apikeys
# Secret key (server-side only — NEVER expose in browser)
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Publishable key (safe to expose in browser — used for Apple Pay / Google Pay Payment Request Button)
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# For local testing, use test keys from dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=your_stripe_test_secret_key_here
# STRIPE_PUBLISHABLE_KEY=your_stripe_test_publishable_key_here

# Your deployed site URL (no trailing slash)
# Vercel sets VERCEL_URL automatically, but set this for Stripe redirect URLs
SITE_URL=https://driverappreciationsolutions.com

# Supabase Authentication — get from https://supabase.com → Project Settings → API
# Both values are CLIENT-SIDE safe (anon key is designed to be public, protected by RLS policies)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
